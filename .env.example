# ─────────────────────────────────────────────────────────────────────────────
# Z.AI API key (required) — used by the Next.js app and the agent service.
# Get your key from the Z.AI dashboard. The SDK reads this variable automatically.
# ─────────────────────────────────────────────────────────────────────────────
ZAI_API_KEY=""

# Legacy alias. Older deployments may have set this instead of ZAI_API_KEY.
# Leave it unset if you've already set ZAI_API_KEY.
# SARVAM_API_KEY=""

# ─────────────────────────────────────────────────────────────────────────────
# Database (optional — only needed if you actually use Prisma features)
# Update with your PostgreSQL connection string.
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ─────────────────────────────────────────────────────────────────────────────
# Agent service (mini-services/agent-service) — optional overrides
# ─────────────────────────────────────────────────────────────────────────────
# Port the Socket.IO agent service listens on. Default: 3003.
# AGENT_SERVICE_PORT=3003

# Path to the agent-browser CLI. Defaults to "agent-browser" (resolved via $PATH).
# Override only if the binary isn't on your $PATH.
# AGENT_BROWSER_PATH="/usr/local/bin/agent-browser"
