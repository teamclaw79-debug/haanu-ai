# ─────────────────────────────────────────────────────────────────────────────
# Gemini API key (required for chat + code generation)
# Get your key from https://aistudio.google.com/app/apikey
# Note: Gemini API access is region-restricted. If you see
# "User location is not supported for the API use" errors, enable billing
# on your Google Cloud project or use a region-supported account.
# ─────────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=""

# ─────────────────────────────────────────────────────────────────────────────
# Z.AI API key (required for web search + image generation features)
# The /api/agent and /api/agent/code routes use Gemini for chat, but
# /api/agent/search and /api/agent/image still use Z.AI's specialized
# functions (web_search, image generation) since Gemini doesn't have
# built-in equivalents. Get your key from the Z.AI dashboard.
# ─────────────────────────────────────────────────────────────────────────────
ZAI_API_KEY=""

# Legacy alias. Older deployments may have set this instead of ZAI_API_KEY.
# SARVAM_API_KEY=""

# ─────────────────────────────────────────────────────────────────────────────
# Database (optional — only needed if you actually use Prisma features)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ─────────────────────────────────────────────────────────────────────────────
# Agent service (mini-services/agent-service) — optional overrides
# ─────────────────────────────────────────────────────────────────────────────
# Port the Socket.IO agent service listens on. Default: 3003.
# AGENT_SERVICE_PORT=3003

# Path to the agent-browser CLI. Defaults to "agent-browser" (resolved via $PATH).
# AGENT_BROWSER_PATH="/usr/local/bin/agent-browser"
